{
  "name": "senior-front-end-topics",
  "version": "0.1.0",
  "private": true,
  "description": "Senior Front-end Developer knowledge & topics — interactive SPA workbooks per level",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter 'workbook-hub' dev",
    "dev:hub": "bun run --filter 'workbook-hub' dev",
    "dev:l1": "bun run --filter 'level-1-fundamentals' dev",
    "dev:l2": "bun run --filter 'level-2-react-rendering' dev",
    "dev:l3": "bun run --filter 'level-3-browser-performance' dev",
    "dev:l4": "bun run --filter 'level-4-data-state' dev",
    "dev:l5": "bun run --filter 'level-5-caching-networking' dev",
    "dev:l6": "bun run --filter 'level-6-security' dev",
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "bun run --filter '*' lint"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
